<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ClawBench" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorAccent</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorSurface">@color/dialog_background</item>
        <item name="colorOnSurface">@color/dialog_text_primary</item>
        <item name="android:statusBarColor">@color/colorPrimary</item>
        <item name="android:navigationBarColor">@color/colorPrimary</item>
        <item name="android:windowBackground">@color/colorPrimary</item>
        <item name="alertDialogTheme">@style/Theme.ClawBench.Dialog</item>
    </style>

    <!-- Dark dialog theme -->
    <style name="Theme.ClawBench.Dialog" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">@color/colorAccent</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorSurface">@color/dialog_background</item>
        <item name="colorOnSurface">@color/dialog_text_primary</item>
        <item name="android:backgroundTint">@color/dialog_background</item>
        <item name="android:textColorPrimary">@color/dialog_text_primary</item>
        <item name="android:textColorSecondary">@color/dialog_text_secondary</item>
        <item name="android:textColorHint">@color/dialog_text_hint</item>
        <item name="android:textAllCaps">false</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.ClawBench.Button.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.ClawBench.Button.Negative</item>
    </style>

    <!-- Positive button: accent blue, slightly bolder -->
    <style name="Widget.ClawBench.Button.Positive" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/dialog_button_positive</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <!-- Negative button: muted -->
    <style name="Widget.ClawBench.Button.Negative" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/dialog_button_negative</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <!-- Browser Activity theme — same base as main, no action bar -->
    <style name="Theme.ClawBench.Browser" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorAccent</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:statusBarColor">@color/browser_toolbar_bg</item>
        <item name="android:navigationBarColor">@color/browser_background</item>
        <item name="android:windowBackground">@color/browser_background</item>
        <item name="alertDialogTheme">@style/Theme.ClawBench.Dialog</item>
    </style>
</resources>
