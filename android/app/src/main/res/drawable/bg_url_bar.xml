<?xml version="1.0" encoding="utf-8"?>
<!-- URL bar background with rounded corners and subtle border -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state: accent border -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/browser_url_bg" />
            <stroke android:width="1.5dp" android:color="@color/colorAccent" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <!-- Default state: subtle border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/browser_url_bg" />
            <stroke android:width="1dp" android:color="@color/browser_url_stroke" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
